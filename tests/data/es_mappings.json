{
  "mappings": {
    "properties": {
      "id": {
        "type": "keyword"
      },
      "case_id": {
        "type": "keyword"
      },
      "submitter_id": {
        "type": "keyword"
      },
      "project_id": {
        "type": "keyword"
      },
      "primary_site": {
        "type": "keyword"
      },
      "disease_type": {
        "type": "keyword"
      },
      "age_at_diagnosis": {
        "type": "integer"
      },
      "vital_status": {
        "type": "keyword"
      },
      "days_to_death": {
        "type": "integer"
      },
      "gender": {
        "type": "keyword"
      },
      "ethnicity": {
        "type": "keyword"
      },
      "race": {
        "type": "keyword"
      },
      "tumor_stage": {
        "type": "keyword"
      },
      "tumor_grade": {
        "type": "keyword"
      },
      "created_datetime": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis"
      },
      "updated_datetime": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis"
      },
      "description": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "files": {
        "type": "nested",
        "properties": {
          "file_id": {
            "type": "keyword"
          },
          "file_name": {
            "type": "keyword"
          },
          "file_size": {
            "type": "long"
          },
          "data_format": {
            "type": "keyword"
          },
          "data_type": {
            "type": "keyword"
          },
          "data_category": {
            "type": "keyword"
          },
          "experimental_strategy": {
            "type": "keyword"
          },
          "platform": {
            "type": "keyword"
          },
          "access": {
            "type": "keyword"
          },
          "state": {
            "type": "keyword"
          },
          "md5sum": {
            "type": "keyword"
          }
        }
      },
      "samples": {
        "type": "nested",
        "properties": {
          "sample_id": {
            "type": "keyword"
          },
          "sample_type": {
            "type": "keyword"
          },
          "sample_type_id": {
            "type": "keyword"
          },
          "tissue_type": {
            "type": "keyword"
          },
          "tumor_code": {
            "type": "keyword"
          },
          "tumor_descriptor": {
            "type": "keyword"
          },
          "portions": {
            "type": "nested",
            "properties": {
              "portion_id": {
                "type": "keyword"
              },
              "weight": {
                "type": "float"
              },
              "is_ffpe": {
                "type": "boolean"
              },
              "analytes": {
                "type": "nested",
                "properties": {
                  "analyte_id": {
                    "type": "keyword"
                  },
                  "analyte_type": {
                    "type": "keyword"
                  },
                  "concentration": {
                    "type": "float"
                  },
                  "aliquots": {
                    "type": "nested",
                    "properties": {
                      "aliquot_id": {
                        "type": "keyword"
                      },
                      "submitter_id": {
                        "type": "keyword"
                      },
                      "amount": {
                        "type": "float"
                      },
                      "concentration": {
                        "type": "float"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "genomic_variants": {
        "type": "nested",
        "properties": {
          "variant_id": {
            "type": "keyword"
          },
          "chromosome": {
            "type": "keyword"
          },
          "start_position": {
            "type": "long"
          },
          "end_position": {
            "type": "long"
          },
          "reference_allele": {
            "type": "keyword"
          },
          "alternate_allele": {
            "type": "keyword"
          },
          "variant_type": {
            "type": "keyword"
          },
          "gene_symbol": {
            "type": "keyword"
          },
          "consequence": {
            "type": "keyword"
          },
          "impact": {
            "type": "keyword"
          },
          "hgvsc": {
            "type": "keyword"
          },
          "hgvsp": {
            "type": "keyword"
          },
          "allele_frequency": {
            "type": "float"
          },
          "depth": {
            "type": "integer"
          },
          "annotations": {
            "type": "nested",
            "properties": {
              "database": {
                "type": "keyword"
              },
              "annotation_id": {
                "type": "keyword"
              },
              "score": {
                "type": "float"
              }
            }
          }
        }
      },
      "treatments": {
        "type": "nested",
        "properties": {
          "treatment_id": {
            "type": "keyword"
          },
          "treatment_type": {
            "type": "keyword"
          },
          "therapeutic_agent": {
            "type": "keyword"
          },
          "days_to_treatment_start": {
            "type": "integer"
          },
          "days_to_treatment_end": {
            "type": "integer"
          },
          "treatment_outcome": {
            "type": "keyword"
          }
        }
      },
      "follow_ups": {
        "type": "nested",
        "properties": {
          "follow_up_id": {
            "type": "keyword"
          },
          "days_to_follow_up": {
            "type": "integer"
          },
          "disease_response": {
            "type": "keyword"
          },
          "progression_or_recurrence": {
            "type": "keyword"
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "study": {
            "type": "keyword"
          },
          "program": {
            "type": "keyword"
          },
          "version": {
            "type": "keyword"
          },
          "data_release": {
            "type": "keyword"
          }
        }
      },
      "summary_stats": {
        "type": "object",
        "properties": {
          "file_count": {
            "type": "integer"
          },
          "file_size_total": {
            "type": "long"
          },
          "sample_count": {
            "type": "integer"
          },
          "variant_count": {
            "type": "integer"
          }
        }
      },
      "tags": {
        "type": "keyword"
      },
      "is_public": {
        "type": "boolean"
      },
      "quality_score": {
        "type": "float"
      },
      "notes": {
        "type": "text",
        "analyzer": "standard"
      }
    }
  },
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 1,
    "index": {
      "max_nested_fields": 100,
      "max_result_window": 10000
    },
    "analysis": {
      "analyzer": {
        "custom_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding"]
        }
      }
    }
  }
}
